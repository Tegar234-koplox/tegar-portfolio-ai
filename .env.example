# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI chatbot estimator
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact email notification via Resend
# Leave empty if you do not want email notification yet.
RESEND_API_KEY=your-resend-api-key
CONTACT_NOTIFICATION_TO=your-email@example.com
CONTACT_NOTIFICATION_FROM=Portfolio Contact <onboarding@resend.dev>

# Used to hash IP before saving analytics/contact/chat metadata.
ANALYTICS_SALT=change-this-random-string
