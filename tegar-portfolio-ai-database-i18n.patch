+import { AnalyticsTracker } from '@/components/analytics/AnalyticsTracker';
+import { LanguageProvider } from '@/lib/i18n/LanguageProvider';
+
+type ProvidersProps = {
+  children: ReactNode;
+};
+
+export function Providers({ children }: ProvidersProps) {
+  return (
+    <LanguageProvider>
+      <AnalyticsTracker />
+      {children}
+    </LanguageProvider>
+  );
+}
